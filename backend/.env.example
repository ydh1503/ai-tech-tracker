# ─── 데이터베이스 ─────────────────────────────────────────────────────────────
# PostgreSQL 연결 URL (asyncpg 드라이버 사용)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_tech_tracker

# ─── 캐시 ──────────────────────────────────────────────────────────────────────
# Redis 연결 URL
REDIS_URL=redis://localhost:6379/0

# ─── Anthropic 인증 (OAuth 토큰 방식) ──────────────────────────────────────────
# Claude.ai Pro/Max 구독의 OAuth 토큰을 사용합니다 (API 사용료 별도 부과 없음)
#
# 발급 방법 (터미널에서 1회 실행):
#   claude setup-token
#   → sk-ant-oat01-... 형태의 토큰 출력 후 아래에 붙여넣기
#
# 토큰 유효기간: 1년 / 재발급: claude setup-token 재실행
ANTHROPIC_API_KEY=sk-ant-oat01-여기에_토큰_붙여넣기

# ─── GitHub API ────────────────────────────────────────────────────────────────
# GitHub Personal Access Token (선택 — 없으면 rate limit 60req/h로 제한)
# https://github.com/settings/tokens 에서 발급 (repo:read 권한 필요)
GITHUB_TOKEN=ghp_...

# ─── 관리자 인증 ───────────────────────────────────────────────────────────────
# 관리자 API용 Bearer 토큰 (임의의 강력한 문자열 사용)
ADMIN_TOKEN=change-me-to-a-strong-secret-token

# ─── CORS ──────────────────────────────────────────────────────────────────────
# 허용할 오리진 목록 (쉼표로 구분)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── 환경 ──────────────────────────────────────────────────────────────────────
# "development" 또는 "production"
ENV=development
